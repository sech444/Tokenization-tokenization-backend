# Development Environment Configuration
# This file contains working defaults for immediate development
# DO NOT use these values in production!

# =============================================================================
# Application Environment
# =============================================================================
RUST_ENV=development
RUST_LOG=debug
RUST_BACKTRACE=1

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080
MAX_CONNECTIONS=100
TIMEOUT_SECONDS=30

# =============================================================================
# Database Configuration (Docker PostgreSQL)
# =============================================================================
# DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/tokenization_db
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_CONNECTION_TIMEOUT=30
DB_IDLE_TIMEOUT=600
POSTGRES_URL="postgres://8cfdde2776b9e0f0662488be70e876ae2894f1a3cd06994b390acf38197d3c4f:sk_qLilo5f9OziArWt4hzbIq@db.prisma.io:5432/?sslmode=require"
PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..9u3ynMWaiif4pJocszlIoC8aOqr489uq5hmZBPBf_R4"
DATABASE_URL="postgres://8cfdde2776b9e0f0662488be70e876ae2894f1a3cd06994b390acf38197d3c4f:sk_qLilo5f9OziArWt4hzbIq@db.prisma.io:5432/?sslmode=require"

# =============================================================================
# JWT Configuration (Development Only!)
# =============================================================================
JWT_SECRET=development-jwt-secret-key-for-tokenization-platform-32-chars-minimum
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_ALGORITHM=HS256

# =============================================================================
# Blockchain Configuration (Local Ganache)
# =============================================================================
BLOCKCHAIN_NETWORK=ganache
BLOCKCHAIN_RPC_URL=http://localhost:8545
# Ganache default private key (first account)
BLOCKCHAIN_PRIVATE_KEY=4f3edf983ac636a65a842ce7c78d9aa706d3b113bce9c46f30d7d21715b23b1d
BLOCKCHAIN_GAS_LIMIT=3000000
BLOCKCHAIN_GAS_PRICE=20000000000

# Smart Contract Addresses (Will be populated after deployment)
CONTRACT_TOKEN_FACTORY=0x0000000000000000000000000000000000000000
CONTRACT_MARKETPLACE=0x0000000000000000000000000000000000000000
CONTRACT_COMPLIANCE=0x0000000000000000000000000000000000000000
CONTRACT_STAKING=0x0000000000000000000000000000000000000000

# =============================================================================
# Development KYC & Compliance (Mock Providers)
# =============================================================================
KYC_PROVIDER=mock
KYC_API_KEY=mock-kyc-api-key-for-development
AML_PROVIDER=mock
AML_API_KEY=mock-aml-api-key-for-development
AUTO_VERIFICATION=true
VERIFICATION_TIMEOUT_HOURS=1

# =============================================================================
# Email Configuration (MailHog for Development)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@tokenization.local
FROM_NAME=Tokenization Platform Dev

# =============================================================================
# Push Notification Configuration (Mock)
# =============================================================================
FIREBASE_KEY=mock-firebase-key-for-development
APNS_KEY=mock-apns-key-for-development
APNS_KEY_ID=mock-key-id
APNS_TEAM_ID=mock-team-id

# =============================================================================
# Redis Configuration (Docker Redis)
# =============================================================================
REDIS_URL=redis://:redis123@localhost:6379

# =============================================================================
# Security Configuration (Development)
# =============================================================================
BCRYPT_COST=4
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=3600
SESSION_TIMEOUT_MINUTES=120
MAX_LOGIN_ATTEMPTS=10
LOCKOUT_DURATION_MINUTES=5

# =============================================================================
# File Storage Configuration (Local)
# =============================================================================
FILE_STORAGE_PATH=./storage/documents
AWS_ACCESS_KEY_ID=mock-access-key
AWS_SECRET_ACCESS_KEY=mock-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=tokenization-dev-documents

# =============================================================================
# Development Features
# =============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_DEBUG_ROUTES=true
SKIP_EMAIL_VERIFICATION=true
MOCK_BLOCKCHAIN=false
MOCK_KYC_PROVIDER=true
MOCK_EXTERNAL_APIS=true

# =============================================================================
# Monitoring & Analytics
# =============================================================================
ANALYTICS_ENABLED=true
METRICS_PORT=9090
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/tokenization.log

# =============================================================================
# External API Keys (Development/Mock)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_mock_stripe_key_for_development
STRIPE_WEBHOOK_SECRET=whsec_mock_webhook_secret
IPGEOLOCATION_API_KEY=mock-geolocation-key

# =============================================================================
# Test Database
# =============================================================================
TEST_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/tokenization_test_db

# =============================================================================
# Backup Configuration (Development)
# =============================================================================
BACKUP_S3_BUCKET=tokenization-dev-backups
BACKUP_ENCRYPTION_KEY=dev-backup-key-not-for-production
BACKUP_SCHEDULE="0 2 * * *"

# =============================================================================
# Quick Start Flags
# =============================================================================
QUICK_START_MODE=true
AUTO_MIGRATE=true
SEED_DATABASE=true
CREATE_ADMIN_USER=true
ADMIN_EMAIL=admin@tokenization.local
ADMIN_PASSWORD=admin123dev
