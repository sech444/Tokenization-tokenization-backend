  "query": "\n        SELECT \n            id, \n            email,\n            status as \"status: _\", \n            last_login,\n            COALESCE(role::text, 'user') as \"role!\", \n            is_active, \n            created_at\n        FROM users\n        ORDER BY created_at DESC\n        LIMIT $1 OFFSET $2\n        ",
