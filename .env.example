# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to version control

# =============================================================================
# Application Environment
# =============================================================================
RUST_ENV=development
RUST_LOG=debug
RUST_BACKTRACE=1

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_CONNECTIONS=100
TIMEOUT_SECONDS=30

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/tokenization_db
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_CONNECTION_TIMEOUT=30
DB_IDLE_TIMEOUT=600

# =============================================================================
# JWT Configuration
# =============================================================================
# Generate a strong secret key (at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-here-at-least-32-characters-long
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_ALGORITHM=HS256

# =============================================================================
# Blockchain Configuration
# =============================================================================
BLOCKCHAIN_NETWORK=localhost
BLOCKCHAIN_RPC_URL=http://localhost:8545
# Private key for deploying contracts (without 0x prefix)
BLOCKCHAIN_PRIVATE_KEY=your-private-key-here
BLOCKCHAIN_GAS_LIMIT=3000000
BLOCKCHAIN_GAS_PRICE=20000000000

# Smart Contract Addresses (deployed contract addresses)
CONTRACT_TOKEN_FACTORY=0x0000000000000000000000000000000000000000
CONTRACT_MARKETPLACE=0x0000000000000000000000000000000000000000
CONTRACT_COMPLIANCE=0x0000000000000000000000000000000000000000
CONTRACT_STAKING=0x0000000000000000000000000000000000000000

# =============================================================================
# KYC & Compliance Configuration
# =============================================================================
# KYC Provider (jumio, onfido, or internal)
KYC_PROVIDER=jumio
KYC_API_KEY=your-kyc-api-key-here

# AML Provider (chainalysis, refinitiv, or internal)
AML_PROVIDER=chainalysis
AML_API_KEY=your-aml-api-key-here

# Compliance Settings
AUTO_VERIFICATION=false
VERIFICATION_TIMEOUT_HOURS=72

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@tokenization.com
FROM_NAME=Tokenization Platform

# =============================================================================
# Push Notification Configuration
# =============================================================================
# Firebase Cloud Messaging
FIREBASE_KEY=your-firebase-server-key-here

# Apple Push Notification Service (APNS)
APNS_KEY=your-apns-private-key-here
APNS_KEY_ID=your-apns-key-id-here
APNS_TEAM_ID=your-apple-team-id-here

# =============================================================================
# Webhook Configuration (Optional)
# =============================================================================
WEBHOOK_URL=https://your-webhook-endpoint.com/notifications

# =============================================================================
# Security Configuration
# =============================================================================
# Bcrypt cost (4-31, higher is more secure but slower)
BCRYPT_COST=12

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# Session Management
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# =============================================================================
# File Storage Configuration (Optional)
# =============================================================================
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=tokenization-documents

# Local file storage path
FILE_STORAGE_PATH=./storage/documents

# =============================================================================
# Redis Configuration (Optional - for caching and rate limiting)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# =============================================================================
# Monitoring & Analytics (Optional)
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn-here

# Analytics tracking
ANALYTICS_ENABLED=true
METRICS_PORT=9090

# =============================================================================
# External API Keys (Optional)
# =============================================================================
# Payment provider keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Geolocation service
IPGEOLOCATION_API_KEY=your-ip-geolocation-api-key

# =============================================================================
# Development/Testing Configuration
# =============================================================================
# Enable/disable features for development
ENABLE_SWAGGER_UI=true
ENABLE_DEBUG_ROUTES=true
SKIP_EMAIL_VERIFICATION=false
MOCK_BLOCKCHAIN=false
MOCK_KYC_PROVIDER=false

# Test database (for running tests)
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/tokenization_test_db

# =============================================================================
# Production Configuration
# =============================================================================
# SSL/TLS Configuration
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/private.key

# Domain configuration
DOMAIN_NAME=tokenization.com
API_BASE_URL=https://api.tokenization.com

# CORS for production
PRODUCTION_CORS_ORIGINS=https://tokenization.com,https://www.tokenization.com

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_S3_BUCKET=tokenization-backups
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/tokenization.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5

# .env.example - Copy this to .env and fill in your values
# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Network Configuration
NETWORK=polygon-mumbai
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Contract Verification
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
VERIFY_CONTRACTS=true

# Deployer Configuration (Use hardware wallet for mainnet!)
PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234
DEPLOYER_ADDRESS=0x742d35Cc6634C0532925a3b8D0C8b73c04

# Platform Addresses
ADMIN_ADDRESS=0x742d35Cc6634C0532925a3b8D1C4Eb0537f23f7eE
COMPLIANCE_OFFICER=0x742d35Cc6634C0532925a3b8D1C4Eb0537f23f7eF
FEE_COLLECTOR=0x742d35Cc6634C0532925a3b8D1C4Eb0537f23f7f0

# Contract Configuration
PLATFORM_FEE_BPS=50                # 0.5% platform fee
MIN_INVESTMENT_AMOUNT=100           # Minimum investment in tokens
MAX_TOKENS_PER_ASSET=1000000       # Maximum tokens per asset

# Security Configuration  
MULTISIG_THRESHOLD=3               # 3 out of 5 multisig
TIMELOCK_DELAY=86400              # 24 hours timelock delay
EMERGENCY_PAUSE_DURATION=604800   # 7 days emergency pause

# Gas Configuration
MAX_GAS_PRICE=100000000000        # 100 gwei max gas price
GAS_LIMIT_BUFFER=20               # 20% buffer for gas estimation
