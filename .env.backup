# Native Development Environment Configuration
# Generated by setup-native.sh

# =============================================================================
# Application Environment
# =============================================================================
RUST_ENV=development
RUST_LOG=debug
RUST_BACKTRACE=1

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080
MAX_CONNECTIONS=100
TIMEOUT_SECONDS=30

# =============================================================================
# Database Configuration (Native PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/tokenization_db
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_CONNECTION_TIMEOUT=30
DB_IDLE_TIMEOUT=600

# =============================================================================
# JWT Configuration (Development Only!)
# =============================================================================
JWT_SECRET=native-development-jwt-secret-key-for-tokenization-platform-minimum-32-chars
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_ALGORITHM=HS256

# =============================================================================
# Blockchain Configuration (Mock for now)
# =============================================================================
BLOCKCHAIN_NETWORK=localhost
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BLOCKCHAIN_GAS_LIMIT=3000000
BLOCKCHAIN_GAS_PRICE=20000000000

# Smart Contract Addresses (Mock)
CONTRACT_TOKEN_FACTORY=0x0000000000000000000000000000000000000000
CONTRACT_MARKETPLACE=0x0000000000000000000000000000000000000000
CONTRACT_COMPLIANCE=0x0000000000000000000000000000000000000000
CONTRACT_STAKING=0x0000000000000000000000000000000000000000

# =============================================================================
# Development KYC & Compliance (Mock Providers)
# =============================================================================
KYC_PROVIDER=mock
KYC_API_KEY=mock-kyc-api-key-for-development
AML_PROVIDER=mock
AML_API_KEY=mock-aml-api-key-for-development
AUTO_VERIFICATION=true
VERIFICATION_TIMEOUT_HOURS=1

# =============================================================================
# Email Configuration (Local SMTP simulator)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@tokenization.local
FROM_NAME=Tokenization Platform Native

# =============================================================================
# Push Notification Configuration (Mock)
# =============================================================================
FIREBASE_KEY=mock-firebase-key-for-development
APNS_KEY=mock-apns-key-for-development
APNS_KEY_ID=mock-key-id
APNS_TEAM_ID=mock-team-id

# =============================================================================
# Redis Configuration (Optional - will use in-memory if not available)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Security Configuration (Development)
# =============================================================================
BCRYPT_COST=4
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=3600
SESSION_TIMEOUT_MINUTES=120
MAX_LOGIN_ATTEMPTS=10
LOCKOUT_DURATION_MINUTES=5

# =============================================================================
# File Storage Configuration (Local)
# =============================================================================
FILE_STORAGE_PATH=./storage/documents

# =============================================================================
# Development Features
# =============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_DEBUG_ROUTES=true
SKIP_EMAIL_VERIFICATION=true
MOCK_BLOCKCHAIN=true
MOCK_KYC_PROVIDER=true
MOCK_EXTERNAL_APIS=true

# =============================================================================
# Test Database
# =============================================================================
TEST_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/tokenization_test_db
