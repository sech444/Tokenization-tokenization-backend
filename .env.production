# Redis (production cluster)
REDIS_URL=redis://:${REDIS_PASSWORD}@prod-redis-host:6379

# Email (SendGrid/SES)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASS}
FROM_EMAIL=noreply@tokenization.com

# Security
BCRYPT_COST=12
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Feature flags
ENABLE_SWAGGER_UI=false
ENABLE_DEBUG_ROUTES=false
MOCK_BLOCKCHAIN=false
MOCK_KYC_PROVIDER=false
MOCK_EXTERNAL_APIS=false


# =============================================================================
# Development KYC & Compliance (Mock Providers)
# =============================================================================
KYC_PROVIDER=mock
KYC_API_KEY=test-kyc-api-key
AML_PROVIDER=mock
AML_API_KEY=mock-aml-api-key-for-development
AUTO_VERIFICATION=true
VERIFICATION_TIMEOUT_HOURS=1

# =============================================================================
# Push Notification Configuration
# =============================================================================
# Firebase Cloud Messaging
FIREBASE_KEY=your-firebase-server-key-here

# Apple Push Notification Service (APNS)
APNS_KEY=your-apns-private-key-here
APNS_KEY_ID=your-apns-key-id-here
APNS_TEAM_ID=your-apple-team-id-here
