# =============================================================================
# EXTERNAL API INTEGRATIONS
# =============================================================================

# Price Oracle Configuration
ORACLE_API_KEY=your-oracle-api-key
ORACLE_BASE_URL=https://api.oracle-provider.com
PRICE_UPDATE_INTERVAL_SECONDS=300

# Payment Provider Configuration
PAYMENT_PROVIDER_API_KEY=your-payment-api-key
PAYMENT_PROVIDER_SECRET=your-payment-secret
PAYMENT_WEBHOOK_URL=http://localhost:8080/api/webhooks/payments

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
RUST_LOG=info,tokenization_platform=debug
RUST_BACKTRACE=1
ENVIRONMENT=development

# Structured Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/application.log
LOG_MAX_SIZE_MB=100
LOG_MAX_FILES=10

# Metrics and Health Checks
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_METRICS_ENDPOINT=true
ENABLE_DEBUG_ROUTES=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ADVANCED_ANALYTICS=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# These settings should only be used in development environments

# Auto-reload on file changes (development only)
AUTO_RELOAD=true

# Mock external services (development only)
MOCK_KYC_PROVIDER=false
MOCK_PAYMENT_PROVIDER=false
MOCK_EMAIL_SERVICE=true

# Development Database Seeding
SEED_DEVELOPMENT_DATA=true
CREATE_ADMIN_USER=true
ADMIN_EMAIL=admin@tokenization-platform.local
